{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumen.local/schemas/sittax_company_panel.schema.json",
  "title": "SittaxObservedCompanyPanel",
  "description": "Observed web payload for Sittax company panel. Not an official public API schema.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "sucesso",
    "nome",
    "alertas"
  ],
  "properties": {
    "$id": {
      "type": [
        "string",
        "null"
      ]
    },
    "sucesso": {
      "type": "boolean"
    },
    "nome": {
      "type": "string"
    },
    "email": {
      "type": [
        "string",
        "null"
      ]
    },
    "alertas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "tipoDoAlerta",
          "tipoStatusAlerta",
          "mensagem"
        ],
        "properties": {
          "$id": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": [
              "string",
              "integer"
            ]
          },
          "tipoDoAlerta": {
            "type": [
              "string",
              "null"
            ]
          },
          "tipoStatusAlerta": {
            "type": [
              "string",
              "null"
            ]
          },
          "mensagem": {
            "type": [
              "string",
              "null"
            ]
          },
          "ciente": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "historicoDoAlerta": {
            "type": "array",
            "items": {
              "type": [
                "object",
                "string"
              ],
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
